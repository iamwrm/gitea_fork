@@ -0,0 +1,462 @@
+// Copyright 2026 The Forgejo Authors. All rights reserved.
+// SPDX-License-Identifier: MIT
+
+package repo
+
+import (
+	"archive/tar"
+	"archive/zip"
+	"bytes"
+	"compress/gzip"
+	"errors"
+	"io"
+	"net/url"
+	"path"
+	"sort"
+	"strings"
+
+	"forgejo.org/modules/httplib"
+	"forgejo.org/modules/typesniffer"
+	"forgejo.org/modules/util"
+	"forgejo.org/services/context"
+)
+
+const maxArchiveFileEntries = 1000
+
+var errArchivePathNotFound = errors.New("archive path not found")
+
+type archiveFileEntry struct {
+	Name        string
+	DisplayName string
+	Link        string
+	IsDir       bool
+	Size        int64
+}
+
+type archiveFileListing struct {
+	Path       string
+	ParentLink string
+	Entries    []archiveFileEntry
+	Truncated  bool
+}
+
+type archiveFileContent struct {
+	Entry    archiveFileEntry
+	Content  []byte
+	TooLarge bool
+}
+
+type archiveFileView struct {
+	Listing *archiveFileListing
+	Content *archiveFileContent
+}
+
+func isSupportedArchiveFileName(name string) bool {
+	name = strings.ToLower(name)
+	return strings.HasSuffix(name, ".zip") || strings.HasSuffix(name, ".tar.gz")
+}
+
+func readArchiveFile(name string, r io.Reader, archivePath, baseLink string, maxContentSize int64) (*archiveFileView, error) {
+	archivePath = cleanArchiveFileName(archivePath)
+	name = strings.ToLower(name)
+	if strings.HasSuffix(name, ".zip") {
+		buf, err := io.ReadAll(r)
+		if err != nil {
+			return nil, err
+		}
+		return readZipArchive(buf, archivePath, baseLink, maxContentSize)
+	}
+	if strings.HasSuffix(name, ".tar.gz") {
+		return readTarGzArchive(r, archivePath, baseLink, maxContentSize)
+	}
+	return nil, errors.New("unsupported archive format")
+}
+
+func readZipArchive(buf []byte, archivePath, baseLink string, maxContentSize int64) (*archiveFileView, error) {
+	zr, err := zip.NewReader(bytes.NewReader(buf), int64(len(buf)))
+	if err != nil {
+		return nil, err
+	}
+
+	builder := newArchiveFileListing()
+	var selected *zip.File
+	var selectedEntry archiveFileEntry
+	for _, file := range zr.File {
+		name := cleanArchiveFileName(file.Name)
+		if name == "" {
+			continue
+		}
+		isDir := file.FileInfo().IsDir()
+		if builder.add(name, isDir, int64(file.UncompressedSize64)) {
+			break
+		}
+		if name == archivePath && !isDir {
+			selected = file
+			selectedEntry = archiveFileEntry{Name: name, DisplayName: path.Base(name), Link: archiveEntryLink(baseLink, name), Size: int64(file.UncompressedSize64)}
+		}
+	}
+
+	if selected != nil {
+		if selected.UncompressedSize64 >= uint64(maxContentSize) {
+			return &archiveFileView{Content: &archiveFileContent{Entry: selectedEntry, TooLarge: true}}, nil
+		}
+		rc, err := selected.Open()
+		if err != nil {
+			return nil, err
+		}
+		defer rc.Close()
+		content, err := io.ReadAll(rc)
+		if err != nil {
+			return nil, err
+		}
+		return &archiveFileView{Content: &archiveFileContent{Entry: selectedEntry, Content: content}}, nil
+	}
+
+	return &archiveFileView{Listing: builder.finish(archivePath, baseLink)}, nil
+}
+
+func readTarGzArchive(r io.Reader, archivePath, baseLink string, maxContentSize int64) (*archiveFileView, error) {
+	gzr, err := gzip.NewReader(r)
+	if err != nil {
+		return nil, err
+	}
+	defer gzr.Close()
+
+	builder := newArchiveFileListing()
+	tr := tar.NewReader(gzr)
+	for {
+		header, err := tr.Next()
+		if errors.Is(err, io.EOF) {
+			break
+		}
+		if err != nil {
+			return nil, err
+		}
+
+		name := cleanArchiveFileName(header.Name)
+		if name == "" {
+			continue
+		}
+		isDir := header.FileInfo().IsDir()
+		if builder.add(name, isDir, header.Size) {
+			break
+		}
+		if name == archivePath && !isDir {
+			entry := archiveFileEntry{Name: name, DisplayName: path.Base(name), Link: archiveEntryLink(baseLink, name), Size: header.Size}
+			if header.Size >= maxContentSize {
+				return &archiveFileView{Content: &archiveFileContent{Entry: entry, TooLarge: true}}, nil
+			}
+			content, err := io.ReadAll(tr)
+			if err != nil {
+				return nil, err
+			}
+			return &archiveFileView{Content: &archiveFileContent{Entry: entry, Content: content}}, nil
+		}
+	}
+	return &archiveFileView{Listing: builder.finish(archivePath, baseLink)}, nil
+}
+
+type archiveFileListingBuilder struct {
+	entries   map[string]archiveFileEntry
+	truncated bool
+}
+
+func newArchiveFileListing() *archiveFileListingBuilder {
+	return &archiveFileListingBuilder{entries: make(map[string]archiveFileEntry)}
+}
+
+func (b *archiveFileListingBuilder) add(name string, isDir bool, size int64) bool {
+	name = cleanArchiveFileName(name)
+	if name == "" {
+		return false
+	}
+
+	parts := strings.Split(name, "/")
+	for i := 1; i < len(parts); i++ {
+		if b.addEntry(strings.Join(parts[:i], "/"), true, 0) {
+			return true
+		}
+	}
+	return b.addEntry(name, isDir, size)
+}
+
+func (b *archiveFileListingBuilder) addEntry(name string, isDir bool, size int64) bool {
+	if _, ok := b.entries[name]; ok {
+		return false
+	}
+	if len(b.entries) >= maxArchiveFileEntries {
+		b.truncated = true
+		return true
+	}
+	b.entries[name] = archiveFileEntry{Name: name, IsDir: isDir, Size: size}
+	return false
+}
+
+func (b *archiveFileListingBuilder) finish(archivePath, baseLink string) *archiveFileListing {
+	entries := make([]archiveFileEntry, 0, len(b.entries))
+	for _, entry := range b.entries {
+		if entry.Name == archivePath || !isArchiveChild(entry.Name, archivePath) {
+			continue
+		}
+		entry.DisplayName = strings.TrimPrefix(entry.Name, archivePath)
+		entry.DisplayName = strings.TrimPrefix(entry.DisplayName, "/")
+		if strings.Contains(entry.DisplayName, "/") {
+			continue
+		}
+		entry.Link = archiveEntryLink(baseLink, entry.Name)
+		entries = append(entries, entry)
+	}
+	sort.Slice(entries, func(i, j int) bool {
+		if entries[i].IsDir != entries[j].IsDir {
+			return entries[i].IsDir
+		}
+		return entries[i].DisplayName < entries[j].DisplayName
+	})
+
+	listing := &archiveFileListing{Path: archivePath, Entries: entries, Truncated: b.truncated}
+	if archivePath != "" {
+		parent := path.Dir(archivePath)
+		if parent == "." {
+			listing.ParentLink = baseLink
+		} else {
+			listing.ParentLink = archiveEntryLink(baseLink, parent)
+		}
+	}
+	return listing
+}
+
+func isArchiveChild(name, archivePath string) bool {
+	if archivePath == "" {
+		return !strings.Contains(name, "/")
+	}
+	return strings.HasPrefix(name, archivePath+"/")
+}
+
+func archiveEntryLink(baseLink, name string) string {
+	return baseLink + "?archive_path=" + url.QueryEscape(name)
+}
+
+func archiveRawLink(baseLink, name string) string {
+	return archiveEntryLink(baseLink, name) + "&archive_raw=1"
+}
+
+func serveArchiveRaw(ctx *context.Context, archiveName string, r io.Reader, archivePath string) error {
+	archivePath = cleanArchiveFileName(archivePath)
+	if archivePath == "" {
+		return errArchivePathNotFound
+	}
+
+	archiveName = strings.ToLower(archiveName)
+	if strings.HasSuffix(archiveName, ".zip") {
+		buf, err := io.ReadAll(r)
+		if err != nil {
+			return err
+		}
+		return serveZipArchiveRaw(ctx, buf, archivePath)
+	}
+	if strings.HasSuffix(archiveName, ".tar.gz") {
+		return serveTarGzArchiveRaw(ctx, r, archivePath)
+	}
+	return errors.New("unsupported archive format")
+}
+
+func serveZipArchiveRaw(ctx *context.Context, buf []byte, archivePath string) error {
+	zr, err := zip.NewReader(bytes.NewReader(buf), int64(len(buf)))
+	if err != nil {
+		return err
+	}
+
+	var dirFound bool
+	dirBuf := bytes.Buffer{}
+	zw := zip.NewWriter(&dirBuf)
+	dirEntryCount := 0
+	for _, file := range zr.File {
+		name := cleanArchiveFileName(file.Name)
+		if name == "" {
+			continue
+		}
+
+		if name == archivePath {
+			if !file.FileInfo().IsDir() {
+				rc, err := file.Open()
+				if err != nil {
+					_ = zw.Close()
+					return err
+				}
+				defer rc.Close()
+				_ = zw.Close()
+				return serveArchiveEntryAttachment(ctx, name, int64(file.UncompressedSize64), rc)
+			}
+			dirFound = true
+		}
+
+		if name == archivePath || isArchiveChild(name, archivePath) {
+			if err := copyZipFileToZip(zw, file, name); err != nil {
+				_ = zw.Close()
+				return err
+			}
+			dirEntryCount++
+		}
+	}
+
+	if dirEntryCount > 0 || dirFound {
+		if err := zw.Close(); err != nil {
+			return err
+		}
+		return serveArchiveZipAttachment(ctx, archivePath, dirBuf.Bytes())
+	}
+	_ = zw.Close()
+	return errArchivePathNotFound
+}
+
+func serveTarGzArchiveRaw(ctx *context.Context, r io.Reader, archivePath string) error {
+	gzr, err := gzip.NewReader(r)
+	if err != nil {
+		return err
+	}
+	defer gzr.Close()
+
+	dirBuf := bytes.Buffer{}
+	zw := zip.NewWriter(&dirBuf)
+	dirEntryCount := 0
+	tr := tar.NewReader(gzr)
+	for {
+		header, err := tr.Next()
+		if errors.Is(err, io.EOF) {
+			break
+		}
+		if err != nil {
+			_ = zw.Close()
+			return err
+		}
+
+		name := cleanArchiveFileName(header.Name)
+		if name == "" {
+			continue
+		}
+		isDir := header.FileInfo().IsDir()
+		if name == archivePath && !isDir {
+			_ = zw.Close()
+			return serveArchiveEntryAttachment(ctx, name, header.Size, tr)
+		}
+
+		if name == archivePath || isArchiveChild(name, archivePath) {
+			if err := copyTarEntryToZip(zw, name, header, tr); err != nil {
+				_ = zw.Close()
+				return err
+			}
+			dirEntryCount++
+		}
+	}
+
+	if dirEntryCount > 0 {
+		if err := zw.Close(); err != nil {
+			return err
+		}
+		return serveArchiveZipAttachment(ctx, archivePath, dirBuf.Bytes())
+	}
+	_ = zw.Close()
+	return errArchivePathNotFound
+}
+
+func serveArchiveEntryAttachment(ctx *context.Context, name string, size int64, reader io.Reader) error {
+	buf := make([]byte, 1024)
+	n, err := util.ReadAtMost(reader, buf)
+	if err != nil {
+		return err
+	}
+	buf = buf[:n]
+
+	contentType := typesniffer.ApplicationOctetStream
+	sniffedType := typesniffer.DetectContentType(buf, path.Base(name))
+	if sniffedType.IsBrowsableBinaryType() || sniffedType.IsText() {
+		contentType = sniffedType.GetMimeType()
+	}
+	httplib.ServeSetHeaders(ctx.Resp, &httplib.ServeHeaderOptions{
+		ContentType:   contentType,
+		ContentLength: &size,
+		Disposition:   "attachment",
+		Filename:      path.Base(name),
+	})
+
+	_, err = io.Copy(ctx.Resp, io.MultiReader(bytes.NewReader(buf), reader))
+	return err
+}
+
+func serveArchiveZipAttachment(ctx *context.Context, archivePath string, content []byte) error {
+	size := int64(len(content))
+	httplib.ServeSetHeaders(ctx.Resp, &httplib.ServeHeaderOptions{
+		ContentType:   "application/zip",
+		ContentLength: &size,
+		Disposition:   "attachment",
+		Filename:      path.Base(archivePath) + ".zip",
+	})
+	_, err := ctx.Resp.Write(content)
+	return err
+}
+
+func copyZipFileToZip(zw *zip.Writer, file *zip.File, name string) error {
+	header, err := zip.FileInfoHeader(file.FileInfo())
+	if err != nil {
+		return err
+	}
+	header.Name = archiveZipEntryName(name, file.FileInfo().IsDir())
+	header.Method = zip.Deflate
+
+	writer, err := zw.CreateHeader(header)
+	if err != nil {
+		return err
+	}
+	if file.FileInfo().IsDir() {
+		return nil
+	}
+
+	rc, err := file.Open()
+	if err != nil {
+		return err
+	}
+	defer rc.Close()
+	_, err = io.Copy(writer, rc)
+	return err
+}
+
+func copyTarEntryToZip(zw *zip.Writer, name string, header *tar.Header, reader io.Reader) error {
+	zipHeader, err := zip.FileInfoHeader(header.FileInfo())
+	if err != nil {
+		return err
+	}
+	zipHeader.Name = archiveZipEntryName(name, header.FileInfo().IsDir())
+	zipHeader.Method = zip.Deflate
+
+	writer, err := zw.CreateHeader(zipHeader)
+	if err != nil {
+		return err
+	}
+	if header.FileInfo().IsDir() {
+		return nil
+	}
+
+	_, err = io.Copy(writer, reader)
+	return err
+}
+
+func archiveZipEntryName(name string, isDir bool) string {
+	if isDir && !strings.HasSuffix(name, "/") {
+		return name + "/"
+	}
+	return name
+}
+
+func cleanArchiveFileName(name string) string {
+	if name == "" {
+		return ""
+	}
+	name = strings.ReplaceAll(name, "\\", "/")
+	name = strings.TrimPrefix(name, "/")
+	name = strings.TrimSuffix(name, "/")
+	name = path.Clean(name)
+	if name == "." || strings.HasPrefix(name, "../") || name == ".." {
+		return ""
+	}
+	return name
+}
