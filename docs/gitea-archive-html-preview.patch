+func TestRepoViewArchiveFiles(t *testing.T) {
+	defer tests.PrepareTestEnv(t)()
+
+	onGiteaRun(t, func(t *testing.T, _ *url.URL) {
+		user := unittest.AssertExistsAndLoadBean(t, &user_model.User{ID: 2})
+		repo := unittest.AssertExistsAndLoadBean(t, &repo_model.Repository{ID: 1})
+		_, err := files_service.ChangeRepoFiles(t.Context(), repo, user, &files_service.ChangeRepoFilesOptions{
+			Message: "add archive preview fixtures",
+			Files: []*files_service.ChangeRepoFile{
+				{
+					Operation:     "create",
+					TreePath:      "archive-preview.zip",
+					ContentReader: bytes.NewReader(makeTestZipArchive(t)),
+				},
+				{
+					Operation:     "create",
+					TreePath:      "archive-preview.tar.gz",
+					ContentReader: bytes.NewReader(makeTestTarGzArchive(t)),
+				},
+			},
+		})
+		require.NoError(t, err)
+
+		testArchive := func(t *testing.T, filename, expectedText string) {
+			t.Helper()
+			req := NewRequestf(t, "GET", "%s/src/branch/master/%s", repo.Link(), filename)
+			resp := MakeRequest(t, req, http.StatusOK)
+			htmlDoc := NewHTMLParser(t, resp.Body)
+
+			archiveTable := htmlDoc.Find(".view-raw table")
+			require.Equal(t, 1, archiveTable.Length())
+			assert.Contains(t, archiveTable.Text(), "docs")
+			assert.Contains(t, archiveTable.Text(), "hello.txt")
+			assert.NotContains(t, archiveTable.Text(), "docs/readme.txt")
+			assert.NotContains(t, htmlDoc.Find(".view-raw").Text(), "View Raw")
+
+			req = NewRequestf(t, "GET", "%s/src/branch/master/%s?archive_path=docs", repo.Link(), filename)
+			resp = MakeRequest(t, req, http.StatusOK)
+			htmlDoc = NewHTMLParser(t, resp.Body)
+			archiveTable = htmlDoc.Find(".view-raw table")
+			require.Equal(t, 1, archiveTable.Length())
+			assert.Contains(t, archiveTable.Text(), "..")
+			assert.Contains(t, archiveTable.Text(), "readme.txt")
+			assert.NotContains(t, archiveTable.Text(), "hello.txt")
+			assert.Greater(t, htmlDoc.Find(`.file-actions a[href*="archive_raw=1"]`).Length(), 0)
+
+			req = NewRequestf(t, "GET", "%s/src/branch/master/%s?archive_path=docs/readme.txt", repo.Link(), filename)
+			resp = MakeRequest(t, req, http.StatusOK)
+			htmlDoc = NewHTMLParser(t, resp.Body)
+			assert.Equal(t, 0, htmlDoc.Find(".view-raw table").Length())
+			assert.Contains(t, htmlDoc.Find(".code-view").Text(), expectedText)
+			assert.Greater(t, htmlDoc.Find(`.file-actions a[href*="archive_raw=1"]`).Length(), 0)
+
+			req = NewRequestf(t, "GET", "%s/src/branch/master/%s?archive_path=docs/logo.png", repo.Link(), filename)
+			resp = MakeRequest(t, req, http.StatusOK)
+			htmlDoc = NewHTMLParser(t, resp.Body)
+			src, ok := htmlDoc.Find(".view-raw img").Attr("src")
+			require.True(t, ok)
+			assert.Contains(t, src, "data:image/png;base64,")
+			assert.NotContains(t, htmlDoc.Find(".view-raw").Text(), "cannot be previewed")
+
+			req = NewRequestf(t, "GET", "%s/src/branch/master/%s?archive_path=docs/blob.bin", repo.Link(), filename)
+			resp = MakeRequest(t, req, http.StatusOK)
+			htmlDoc = NewHTMLParser(t, resp.Body)
+			assert.Contains(t, htmlDoc.Find(".ui.error.message").Text(), "cannot be previewed")
+
+			req = NewRequestf(t, "GET", "%s/src/branch/master/%s?archive_path=docs/readme.txt&archive_raw=1", repo.Link(), filename)
+			resp = MakeRequest(t, req, http.StatusOK)
+			assertContentDispositionFilename(t, resp.Header().Get("Content-Disposition"), "readme.txt")
+			assert.Equal(t, expectedText, resp.Body.String())
+
+			req = NewRequestf(t, "GET", "%s/src/branch/master/%s?archive_path=docs&archive_raw=1", repo.Link(), filename)
+			resp = MakeRequest(t, req, http.StatusOK)
+			assertContentDispositionFilename(t, resp.Header().Get("Content-Disposition"), "docs.zip")
+			zr, err := zip.NewReader(bytes.NewReader(resp.Body.Bytes()), int64(resp.Body.Len()))
+			require.NoError(t, err)
+			names := map[string]bool{}
+			for _, file := range zr.File {
+				names[file.Name] = true
+			}
+			assert.Contains(t, names, "docs/readme.txt")
+			assert.Contains(t, names, "docs/logo.png")
+		}
+
+		t.Run("zip", func(t *testing.T) {
+			defer tests.PrintCurrentTest(t)()
+			testArchive(t, "archive-preview.zip", "zip readme")
+		})
+		t.Run("tar.gz", func(t *testing.T) {
+			defer tests.PrintCurrentTest(t)()
+			testArchive(t, "archive-preview.tar.gz", "tar readme")
+		})
+	})
+}
+
+func assertContentDispositionFilename(t *testing.T, header, expected string) {
+	t.Helper()
+	_, params, err := mime.ParseMediaType(header)
+	require.NoError(t, err)
+	assert.Equal(t, expected, params["filename"])
+}
+
+func TestRepoViewHTMLPreview(t *testing.T) {
+	defer tests.PrepareTestEnv(t)()
+
+	onGiteaRun(t, func(t *testing.T, _ *url.URL) {
+		user := unittest.AssertExistsAndLoadBean(t, &user_model.User{ID: 2})
+		repo := unittest.AssertExistsAndLoadBean(t, &repo_model.Repository{ID: 1})
+		_, err := files_service.ChangeRepoFiles(t.Context(), repo, user, &files_service.ChangeRepoFilesOptions{
+			Message: "add html preview fixtures",
+			Files: []*files_service.ChangeRepoFile{
+				{
+					Operation: "create",
+					TreePath:  "html-preview-tool.html",
+					ContentReader: strings.NewReader(`<!doctype html>
+<html>
+<head><script src="html-preview-tool.js"></script></head>
+<body><button id="run">Hash</button></body>
+</html>`),
+				},
+				{
+					Operation:     "create",
+					TreePath:      "html-preview-tool.js",
+					ContentReader: strings.NewReader(`document.body.dataset.loaded = "yes";`),
+				},
+			},
+		})
+		require.NoError(t, err)
+
+		req := NewRequestf(t, "GET", "%s/src/branch/master/html-preview-tool.html", repo.Link())
+		resp := MakeRequest(t, req, http.StatusOK)
+		htmlDoc := NewHTMLParser(t, resp.Body)
+		iframe := htmlDoc.Find(`.file-view.html-preview iframe[sandbox="allow-scripts"]`)
+		require.Equal(t, 1, iframe.Length())
+		src, ok := iframe.Attr("src")
+		require.True(t, ok)
+		assert.Equal(t, repo.Link()+"/render/branch/master/html-preview-tool.html", src)
+		assert.Greater(t, htmlDoc.Find(".file-actions a.file-view-toggle-rendered.active").Length(), 0)
+		assert.Contains(t, resp.Header().Get("Content-Security-Policy"), "frame-src 'self'")
+
+		req = NewRequestf(t, "GET", "%s/src/branch/master/html-preview-tool.html?display=source", repo.Link())
+		resp = MakeRequest(t, req, http.StatusOK)
+		htmlDoc = NewHTMLParser(t, resp.Body)
+		assert.Equal(t, 0, htmlDoc.Find(`.file-view.html-preview iframe`).Length())
+		assert.Contains(t, htmlDoc.Find(".code-view").Text(), "Hash")
+
+		req = NewRequestf(t, "GET", "%s/render/branch/master/html-preview-tool.html", repo.Link())
+		resp = MakeRequest(t, req, http.StatusOK)
+		assert.Contains(t, resp.Header().Get("Content-Type"), "text/html")
+		assert.Contains(t, resp.Header().Get("Content-Security-Policy"), "sandbox allow-scripts")
+		assert.Contains(t, resp.Body.String(), `<button id="run">Hash</button>`)
+
+		req = NewRequestf(t, "GET", "%s/render/branch/master/html-preview-tool.js", repo.Link())
+		resp = MakeRequest(t, req, http.StatusOK)
+		assert.Contains(t, resp.Header().Get("Content-Type"), "javascript")
+		assert.Contains(t, resp.Body.String(), `document.body.dataset.loaded`)
+	})
+}
+
+func makeTestZipArchive(t *testing.T) []byte {
+	t.Helper()
+	var buf bytes.Buffer
+	zw := zip.NewWriter(&buf)
+	_, err := zw.Create("docs/")
+	require.NoError(t, err)
+	w, err := zw.Create("docs/readme.txt")
+	require.NoError(t, err)
+	_, err = w.Write([]byte("zip readme"))
+	require.NoError(t, err)
+	w, err = zw.Create("docs/logo.png")
+	require.NoError(t, err)
+	_, err = w.Write(testPNGContent)
+	require.NoError(t, err)
+	w, err = zw.Create("docs/blob.bin")
+	require.NoError(t, err)
+	_, err = w.Write(testBinaryContent)
+	require.NoError(t, err)
+	w, err = zw.Create("hello.txt")
+	require.NoError(t, err)
+	_, err = w.Write([]byte("hello zip"))
+	require.NoError(t, err)
+	require.NoError(t, zw.Close())
+	return buf.Bytes()
+}
+
+func makeTestTarGzArchive(t *testing.T) []byte {
+	t.Helper()
+	var buf bytes.Buffer
+	gzw := gzip.NewWriter(&buf)
+	tw := tar.NewWriter(gzw)
+	require.NoError(t, tw.WriteHeader(&tar.Header{Name: "docs", Typeflag: tar.TypeDir, Mode: 0o755}))
+	writeTarFile(t, tw, "docs/readme.txt", "tar readme")
+	writeTarFileBytes(t, tw, "docs/logo.png", testPNGContent)
+	writeTarFileBytes(t, tw, "docs/blob.bin", testBinaryContent)
+	writeTarFile(t, tw, "hello.txt", "hello tar")
+	require.NoError(t, tw.Close())
+	require.NoError(t, gzw.Close())
+	return buf.Bytes()
+}
+
+func writeTarFile(t *testing.T, tw *tar.Writer, name, content string) {
+	t.Helper()
+	writeTarFileBytes(t, tw, name, []byte(content))
+}
+
+func writeTarFileBytes(t *testing.T, tw *tar.Writer, name string, content []byte) {
+	t.Helper()
+	require.NoError(t, tw.WriteHeader(&tar.Header{Name: name, Typeflag: tar.TypeReg, Mode: 0o644, Size: int64(len(content))}))
+	_, err := tw.Write(content)
+	require.NoError(t, err)
+}
